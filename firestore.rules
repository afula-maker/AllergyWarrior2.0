rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Product Cache Rules
    match /products/{productId} {
      // Allow anyone to read the cache to speed up their scans
      allow read: if true;
      
      // Only authenticated users can contribute to the cache
      allow create, update: if isAuthenticated() && 
        request.resource.data.keys().hasAll(['productName', 'ingredients', 'isEdible', 'lastAnalyzed']) &&
        request.resource.data.productName is string &&
        request.resource.data.ingredients is list &&
        request.resource.data.isEdible is bool;
    }

    // User Data (Optional for future persistence)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
